<?xml version="1.0" encoding="utf-8"?>
<!--
    Cleartext HTTP autorisé globalement — tout le trafic réseau de Fialka
    transite par le proxy Tor SOCKS5 (chiffrement bout-en-bout dans le tunnel).
    La restriction cleartext serait redondante et empêcherait de joindre les
    nœuds Monero en HTTP (format wallet2_api standard).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
