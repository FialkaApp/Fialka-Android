<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorToolbarBackground"
        android:elevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:menu="@menu/menu_chat"
        app:titleTextColor="?attr/colorToolbarTitle">

        <!-- Custom clickable toolbar content -->
        <LinearLayout
            android:id="@+id/toolbarContent"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorToolbarTitle"
                android:textSize="18sp"
                android:textStyle="bold"
                android:singleLine="true" />

            <TextView
                android:id="@+id/tvFingerprintBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:singleLine="true" />

            <TextView
                android:id="@+id/tvEphemeralBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B2DFDB"
                android:textSize="11sp"
                android:singleLine="true"
                android:visibility="gone" />

        </LinearLayout>

    </com.google.android.material.appbar.MaterialToolbar>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="?attr/colorChatBackground"
        android:clipToPadding="false"
        android:padding="4dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toTopOf="@id/inputBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:stackFromEnd="true" />

    <TextView
        android:id="@+id/tvPendingBanner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorInfoBoxBackground"
        android:gravity="center"
        android:paddingVertical="14dp"
        android:paddingHorizontal="16dp"
        android:text="@string/pending_acceptance"
        android:textColor="?attr/colorOrangeWarning"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/inputBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorInputBar"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_input_message"
            android:hint="@string/type_message_hint"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="4"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:textSize="15sp" />

        <ImageButton
            android:id="@+id/btnAttach"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Attach file"
            android:src="@drawable/ic_attach"
            android:scaleType="center"
            android:tint="?attr/colorOnSurface" />

        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="?attr/colorPrimary"
            android:contentDescription="@string/send"
            android:src="@drawable/ic_send"
            android:scaleType="center" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
