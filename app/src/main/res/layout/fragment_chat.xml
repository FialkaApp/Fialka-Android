<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorToolbarBackground"
        android:elevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:menu="@menu/menu_chat"
        app:titleTextColor="?attr/colorToolbarTitle">

        <!-- Custom clickable toolbar content -->
        <LinearLayout
            android:id="@+id/toolbarContent"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorToolbarTitle"
                android:textSize="18sp"
                android:textStyle="bold"
                android:singleLine="true" />

            <TextView
                android:id="@+id/tvFingerprintBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:singleLine="true"
                android:letterSpacing="0.02" />

            <TextView
                android:id="@+id/tvEphemeralBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorTertiary"
                android:textSize="11sp"
                android:singleLine="true"
                android:visibility="gone" />

        </LinearLayout>

    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Mailbox fetch banner -->
    <LinearLayout
        android:id="@+id/fetchBanner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingVertical="10dp"
        android:paddingHorizontal="16dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <ProgressBar
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginEnd="8dp"
            android:indeterminateTint="?attr/colorPrimary"
            style="?android:attr/progressBarStyleSmall" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/chat_mailbox_fetching"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="13sp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="?attr/colorChatBackground"
        android:clipToPadding="false"
        android:padding="4dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toTopOf="@id/replyBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fetchBanner"
        app:stackFromEnd="true" />

    <TextView
        android:id="@+id/tvPendingBanner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorInfoBoxBackground"
        android:gravity="center"
        android:paddingVertical="14dp"
        android:paddingHorizontal="16dp"
        android:text="@string/pending_acceptance"
        android:textColor="?attr/colorOrangeWarning"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Transparent overlay to dismiss icons on outside tap -->
    <View
        android:id="@+id/attachmentOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Expandable attachment icons (Session-style, above + button) ── -->
    <LinearLayout
        android:id="@+id/attachmentIcons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/inputBar"
        app:layout_constraintEnd_toEndOf="@id/inputBar"
        android:layout_marginEnd="56dp">

        <!-- Monero XMR (toujours visible, wallet check au tap) -->
        <ImageButton
            android:id="@+id/btnPickMonero"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_circle_option_orange"
            android:contentDescription="@string/cd_xmr_payment"
            android:src="@drawable/ic_monero"
            android:scaleType="centerInside"
            android:padding="4dp" />

        <!-- File -->
        <ImageButton
            android:id="@+id/btnPickFile"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_circle_option_blue"
            android:contentDescription="@string/cd_file"
            android:src="@drawable/ic_file"
            android:scaleType="center"
            android:tint="@android:color/white" />

        <!-- Photo -->
        <ImageButton
            android:id="@+id/btnPickPhoto"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_circle_option_purple"
            android:contentDescription="@string/cd_photo"
            android:src="@drawable/ic_photo"
            android:scaleType="center"
            android:tint="@android:color/white" />

        <!-- Camera -->
        <ImageButton
            android:id="@+id/btnPickCamera"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_circle_option_red"
            android:contentDescription="@string/cd_camera"
            android:src="@drawable/ic_camera"
            android:scaleType="center"
            android:tint="@android:color/white" />

    </LinearLayout>

    <!-- Reply preview bar — shown when user long-presses "Répondre" -->
    <LinearLayout
        android:id="@+id/replyBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/colorSurface"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/inputBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <View
            android:layout_width="3dp"
            android:layout_height="32dp"
            android:background="?attr/colorPrimary"
            android:layout_marginEnd="10dp" />

        <TextView
            android:id="@+id/tvReplyPreview"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:textColor="?android:attr/textColorSecondary" />

        <ImageButton
            android:id="@+id/btnCancelReply"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            android:contentDescription="@string/cd_cancel_reply"
            android:scaleType="center" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/inputBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorInputBar"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_input_message"
            android:hint="@string/type_message_hint"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="4"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:textSize="15sp" />

        <!-- Voice recording overlay — replaces etMessage while recording (visibility=gone at rest) -->
        <LinearLayout
            android:id="@+id/recordingOverlay"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:background="@drawable/bg_input_message"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvRecordingTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="?attr/colorPrimary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRecordingHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/chat_release_to_send"
                android:textColor="?attr/colorOnSurface"
                android:textSize="11sp"
                android:alpha="0.6" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnAttach"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_attach_file"
            android:src="@drawable/ic_add"
            android:scaleType="center"
            android:tint="?attr/colorOnSurface" />

        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="?attr/colorPrimary"
            android:contentDescription="@string/send"
            android:src="@drawable/ic_send"
            android:scaleType="center" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
