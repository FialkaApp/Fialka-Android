<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Color preview bar -->
        <View
            android:id="@+id/themePreview"
            android:layout_width="match_parent"
            android:layout_height="56dp" />

        <!-- Accent stripe at bottom of preview -->
        <View
            android:id="@+id/themeAccent"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_below="@id/themePreview" />

        <!-- Theme name + check row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/themeAccent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <TextView
                android:id="@+id/themeName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/themeCheck"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_check_circle"
                android:visibility="gone"
                android:contentDescription="selected" />
        </LinearLayout>

    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>
