<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorToolbarBackground"
        android:elevation="0dp"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="?attr/colorToolbarIcon"
        app:title="@string/disguise_screen_title"
        app:titleTextColor="?attr/colorToolbarTitle" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <!-- Subtitle -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/disguise_screen_subtitle"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="13sp"
                android:paddingBottom="16dp" />

            <!-- Fialka (default) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDisguiseFialka"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@mipmap/ic_launcher"
                        android:scaleType="centerInside"
                        android:contentDescription="@string/disguise_option_fialka" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp"
                        android:text="@string/disguise_option_fialka"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/checkDisguiseFialka"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_check"
                        android:visibility="gone"
                        android:contentDescription="" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Calculatrice -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDisguiseCalculator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@color/disguise_bg_calculator"
                        android:src="@drawable/ic_disguise_calculator"
                        android:scaleType="centerInside"
                        android:contentDescription="@string/disguise_label_calculator" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp"
                        android:text="@string/disguise_label_calculator"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/checkDisguiseCalculator"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_check"
                        android:visibility="gone"
                        android:contentDescription="" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Météo -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDisguiseWeather"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@color/disguise_bg_weather"
                        android:src="@drawable/ic_disguise_weather"
                        android:scaleType="centerInside"
                        android:contentDescription="@string/disguise_label_weather" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp"
                        android:text="@string/disguise_label_weather"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/checkDisguiseWeather"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_check"
                        android:visibility="gone"
                        android:contentDescription="" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Notes -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDisguiseNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@color/disguise_bg_notes"
                        android:src="@drawable/ic_disguise_notes"
                        android:scaleType="centerInside"
                        android:contentDescription="@string/disguise_label_notes" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp"
                        android:text="@string/disguise_label_notes"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/checkDisguiseNotes"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_check"
                        android:visibility="gone"
                        android:contentDescription="" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Horloge -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDisguiseClock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@color/disguise_bg_clock"
                        android:src="@drawable/ic_disguise_clock"
                        android:scaleType="centerInside"
                        android:contentDescription="@string/disguise_label_clock" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp"
                        android:text="@string/disguise_label_clock"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/checkDisguiseClock"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_check"
                        android:visibility="gone"
                        android:contentDescription="" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Note d'information -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/info_box_background"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/info_box_stroke"
                app:strokeWidth="1dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:text="Le changement d\u2019ic\u00f4ne prend effet lorsque vous quittez l\u2019application. Le nom affich\u00e9 dans le lanceur changera aussi."
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="13sp"
                    android:lineSpacingExtra="2dp" />

            </com.google.android.material.card.MaterialCardView>

            <!-- ── Options calculatrice réelle (visible seulement si calculatrice active) ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCoverOptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/orange_500"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="&#128272; Mode calculatrice r\u00e9elle"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="L\u2019app s\u2019ouvre comme une vraie calculatrice. Entrez votre code secret pour acc\u00e9der \u00e0 Fialka."
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp"
                        android:paddingBottom="16dp" />

                    <!-- Toggle row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Activer"
                            android:textColor="?android:attr/textColorPrimary"
                            android:textSize="15sp" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchCoverMode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                    <!-- Secret sequence row (visible only when switch ON) -->
                    <LinearLayout
                        android:id="@+id/layoutSecretRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="8dp"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/cover_sequence_label"
                                android:textColor="?android:attr/textColorPrimary"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tvCurrentSecret"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="monospace"
                                android:textColor="?android:attr/textColorSecondary"
                                android:textSize="12sp"
                                android:maxLength="24"
                                android:ellipsize="end"
                                android:singleLine="true" />

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEditSecret"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="@string/cover_setup_configure" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
