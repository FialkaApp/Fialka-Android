<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <!-- FIXED AppBar — no scrollFlags = never hides -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorToolbarBackground"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="?attr/colorToolbarBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="4dp"
                android:paddingTop="18dp"
                android:paddingBottom="6dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.18"
                        android:text="@string/conversations_eyebrow"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/conversations_title"
                        android:textColor="?attr/colorToolbarTitle"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="?attr/colorToolbarBackground"
                android:elevation="0dp"
                app:subtitle="chiffr\u00e9e de bout en bout \uD83D\uDD12"
                app:subtitleTextColor="?attr/colorTextSecondary"
                app:title=""
                app:titleTextColor="?attr/colorToolbarTitle"
                app:menu="@menu/menu_conversations" />

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Contact requests banner (hidden by default) -->
        <TextView
            android:id="@+id/tvRequestsHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorInfoBoxBackground"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="@string/pending_requests_header"
            android:textColor="?attr/colorOrangeWarning"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRequests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <!-- SwipeRefresh wraps the full pager — pull from anywhere works -->
        <com.fialkaapp.fialka.ui.conversations.HorizontalAwareSwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/viewPager"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </com.fialkaapp.fialka.ui.conversations.HorizontalAwareSwipeRefreshLayout>

        <!-- Floating pill tab bar — full-width indicator so text never overflows -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="32dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant">

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayout"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="@android:color/transparent"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                app:tabGravity="fill"
                app:tabMode="fixed"
                app:tabIndicator="@drawable/tab_indicator_pill"
                app:tabIndicatorHeight="52dp"
                app:tabIndicatorFullWidth="true"
                app:tabIndicatorGravity="center"
                app:tabIndicatorColor="?attr/colorPrimary"
                app:tabSelectedTextColor="?attr/colorOnPrimary"
                app:tabTextColor="?attr/colorOnSurfaceVariant"
                app:tabIconTint="@color/tab_icon_tint"
                app:tabRippleColor="@android:color/transparent"
                app:tabTextAppearance="@style/TextAppearance.Material3.LabelMedium"
                app:tabPaddingStart="0dp"
                app:tabPaddingEnd="0dp" />

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- FAB above the floating card: 64dp tab + 16dp marginBottom + 10dp marginTop + 16dp gap -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabNewChat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="116dp"
        android:contentDescription="@string/new_chat"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="?attr/colorPrimary"
        app:tint="?android:attr/colorBackground" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>