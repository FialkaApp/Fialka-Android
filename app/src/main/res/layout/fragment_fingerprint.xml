<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorToolbarBackground"
        android:elevation="0dp"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="?attr/colorToolbarIcon"
        app:title="Empreinte de sécurité"
        app:titleTextColor="?attr/colorToolbarTitle" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Explanation -->
            <TextView
                android:id="@+id/tvExplanation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vérifiez que les emojis ci-dessous sont identiques sur les deux téléphones pour confirmer que la conversation est sécurisée."
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="14sp" />

            <!-- Fingerprint card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Toggle icon (tap to switch emoji/QR) -->
                    <TextView
                        android:id="@+id/tvToggleIcon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔐"
                        android:textSize="32sp" />

                    <TextView
                        android:id="@+id/tvToggleHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Appuyez pour voir le QR code"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="11sp" />

                    <!-- Emoji fingerprint -->
                    <TextView
                        android:id="@+id/tvFingerprint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:letterSpacing="0.05"
                        android:textSize="28sp" />

                    <!-- QR code (hidden by default) -->
                    <ImageView
                        android:id="@+id/ivQrCode"
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:layout_marginTop="12dp"
                        android:contentDescription="QR Code de l'empreinte"
                        android:scaleType="fitCenter"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvContactLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Verification status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvVerificationStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Scan QR button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScanQr"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="📷 Scanner le QR code du contact"
                android:textAllCaps="false"
                app:cornerRadius="8dp"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp" />

            <!-- Verify manually button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerify"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="✅ J'ai vérifié manuellement"
                android:textAllCaps="false"
                app:backgroundTint="@color/primary"
                app:cornerRadius="8dp" />

            <!-- Info box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_info_box"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💡 Comment vérifier ?"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Deux méthodes :\n\n🔢 Emojis — Comparez visuellement les emojis en personne ou par appel vidéo.\n\n📷 QR Code — Scannez le QR code affiché sur le téléphone de votre contact. La vérification est automatique.\n\nSi les empreintes ne correspondent pas, la conversation pourrait être compromise (attaque MITM)."
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
