<?xml version="1.0" encoding="utf-8"?>
<!--
  Bottom sheet pour définir la séquence secrète de la calculatrice cover.
  Étape 1 : entrer la séquence | Étape 2 : confirmer.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface"
    android:orientation="vertical">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:background="#44FFFFFF"
        android:importantForAccessibility="no" />

    <!-- Step indicator -->
    <TextView
        android:id="@+id/tvSetupStep"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingBottom="4dp"
        android:textColor="@color/orange_500"
        android:textSize="12sp"
        android:textAllCaps="true"
        android:letterSpacing="0.08" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvSetupTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingBottom="16dp"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Sequence display (monospace, shows keys as typed) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tvSequenceDisplay"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_sequence_display"
            android:fontFamily="monospace"
            android:gravity="center_vertical|end"
            android:paddingHorizontal="14dp"
            android:paddingVertical="12dp"
            android:singleLine="true"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:hint="—"
            android:textColorHint="#666666" />

        <ImageButton
            android:id="@+id/btnSequenceBackspace"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_backspace"
            android:tint="#AAAAAA"
            android:contentDescription="Effacer dernier" />

    </LinearLayout>

    <!-- ── Calculator pad (compact) ── -->

    <!-- Row 1: AC  +/-  %  ÷ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingBottom="6dp">

        <Button android:id="@+id/setupBtnClear"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_marginHorizontal="4dp" android:background="@drawable/bg_calc_function"
            android:text="AC" android:textColor="#000000" android:textSize="17sp" android:stateListAnimator="@null" />
        <Button android:id="@+id/setupBtnPlusMinus"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_marginHorizontal="4dp" android:background="@drawable/bg_calc_function"
            android:text="+/−" android:textColor="#000000" android:textSize="17sp" android:stateListAnimator="@null" android:enabled="false" android:alpha="0.4" />
        <Button android:id="@+id/setupBtnPercent"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_marginHorizontal="4dp" android:background="@drawable/bg_calc_function"
            android:text="%" android:textColor="#000000" android:textSize="17sp" android:stateListAnimator="@null" android:enabled="false" android:alpha="0.4" />
        <Button android:id="@+id/setupBtnDivide"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_marginHorizontal="4dp" android:background="@drawable/bg_calc_operator"
            android:text="÷" android:textColor="#FFFFFF" android:textSize="22sp" android:stateListAnimator="@null" />
    </LinearLayout>

    <!-- Row 2: 7  8  9  × -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingBottom="6dp">

        <Button android:id="@+id/setupBtn7"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_marginHorizontal="4dp" android:background="@drawable/bg_calc_number"
            android:text="7" android:textColor="#FFFFFF" android:textSize="19sp" android:stateListAnimator="@null" />
        <Button android:id="@+id/setupBtn8"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_marginHorizontal="4dp" android:background="@drawable/bg_calc_number"
            android:text="8" android:textColor="#FFFFFF" android:textSize="19sp" android:stateListAnimator="@null" />
        <Button android:id="@+id/setupBtn9"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_marginHorizontal="4dp" android:background="@drawable/bg_calc_number"
            android:text="9" android:textColor="#FFFFFF" android:textSize="19sp" android:stateListAnimator="@null" />
        <Button android:id="@+id/setupBtnMultiply"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_marginHorizontal="4dp" android:background="@drawable/bg_calc_operator"
            android:text="×" android:textColor="#FFFFFF" android:textSize="22sp" android:stateListAnimator="@null" />
    </LinearLayout>

    <!-- Row 3: 4  5  6  − -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingBottom="6dp">

        <Button android:id="@+id/setupBtn4"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_marginHorizontal="4dp" android:background="@drawable/bg_calc_number"
            android:text="4" android:textColor="#FFFFFF" android:textSize="19sp" android:stateListAnimator="@null" />
        <Button android:id="@+id/setupBtn5"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_marginHorizontal="4dp" android:background="@drawable/bg_calc_number"
            android:text="5" android:textColor="#FFFFFF" android:textSize="19sp" android:stateListAnimator="@null" />
        <Button android:id="@+id/setupBtn6"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_marginHorizontal="4dp" android:background="@drawable/bg_calc_number"
            android:text="6" android:textColor="#FFFFFF" android:textSize="19sp" android:stateListAnimator="@null" />
        <Button android:id="@+id/setupBtnMinus"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_marginHorizontal="4dp" android:background="@drawable/bg_calc_operator"
            android:text="−" android:textColor="#FFFFFF" android:textSize="24sp" android:stateListAnimator="@null" />
    </LinearLayout>

    <!-- Row 4: 1  2  3  + -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingBottom="6dp">

        <Button android:id="@+id/setupBtn1"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_marginHorizontal="4dp" android:background="@drawable/bg_calc_number"
            android:text="1" android:textColor="#FFFFFF" android:textSize="19sp" android:stateListAnimator="@null" />
        <Button android:id="@+id/setupBtn2"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_marginHorizontal="4dp" android:background="@drawable/bg_calc_number"
            android:text="2" android:textColor="#FFFFFF" android:textSize="19sp" android:stateListAnimator="@null" />
        <Button android:id="@+id/setupBtn3"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_marginHorizontal="4dp" android:background="@drawable/bg_calc_number"
            android:text="3" android:textColor="#FFFFFF" android:textSize="19sp" android:stateListAnimator="@null" />
        <Button android:id="@+id/setupBtnPlus"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_marginHorizontal="4dp" android:background="@drawable/bg_calc_operator"
            android:text="+" android:textColor="#FFFFFF" android:textSize="24sp" android:stateListAnimator="@null" />
    </LinearLayout>

    <!-- Row 5: 0(wide)  ,  = -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingBottom="6dp">

        <Button android:id="@+id/setupBtn0"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="2"
            android:layout_marginHorizontal="4dp" android:background="@drawable/bg_calc_zero"
            android:text="0" android:textColor="#FFFFFF" android:textSize="19sp"
            android:gravity="center_vertical|start" android:paddingStart="24dp" android:stateListAnimator="@null" />
        <Button android:id="@+id/setupBtnDot"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_marginHorizontal="4dp" android:background="@drawable/bg_calc_number"
            android:text="," android:textColor="#FFFFFF" android:textSize="24sp" android:stateListAnimator="@null" />
        <Button android:id="@+id/setupBtnEquals"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_marginHorizontal="4dp" android:background="@drawable/bg_calc_operator"
            android:text="=" android:textColor="#FFFFFF" android:textSize="22sp" android:stateListAnimator="@null" />
    </LinearLayout>

    <!-- Footer buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSetupCancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/cover_setup_cancel" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSetupNext"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/cover_setup_next"
            android:enabled="false" />

    </LinearLayout>

</LinearLayout>
