<?xml version="1.0" encoding="utf-8"?>
<!--
  fragment_wallet_home.xml
  Four sections switched by BottomNavigationView:
    1. homeSection    — balance card + recent transactions
    2. receiveSection — primary address + QR code
    3. historySection — full transaction RecyclerView
    4. settingsSection — server URL, manual sync, wipe wallet
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/walletToolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorToolbarBackground"
        android:elevation="0dp"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationContentDescription="@string/back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/wallet_home_title"
                android:textColor="?attr/colorToolbarTitle"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWalletSyncStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="?attr/colorToolbarTitle"
                android:alpha="0.65"
                tools:text="Synchronisé il y a 2 min" />

        </LinearLayout>

    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Main content area: only one section visible at a time -->
    <FrameLayout
        android:id="@+id/walletContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/walletToolbar"
        app:layout_constraintBottom_toTopOf="@id/walletBottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ── SECTION 1: Home (balance + recent transactions) ─────────── -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/homeSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Balance card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="?attr/colorToolbarBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/wallet_balance_label"
                            android:textSize="12sp"
                            android:textColor="?attr/colorToolbarTitle"
                            android:alpha="0.65"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tvBalance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorToolbarTitle"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="16dp"
                            tools:text="0.00000 XMR" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#20FFFFFF"
                            android:layout_marginBottom="12dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/wallet_block_label"
                                    android:textSize="11sp"
                                    android:textColor="?attr/colorToolbarTitle"
                                    android:alpha="0.6" />

                                <TextView
                                    android:id="@+id/tvBlockHeight"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="13sp"
                                    android:textColor="?attr/colorToolbarTitle"
                                    tools:text="3 241 580" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/wallet_scan_label"
                                    android:textSize="11sp"
                                    android:textColor="?attr/colorToolbarTitle"
                                    android:alpha="0.6" />

                                <ProgressBar
                                    android:id="@+id/progressSync"
                                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="4dp"
                                    android:layout_marginTop="4dp"
                                    android:max="100"
                                    android:progress="0"
                                    android:visibility="gone" />

                                <TextView
                                    android:id="@+id/tvScanProgress"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="13sp"
                                    android:textColor="?attr/colorToolbarTitle"
                                    tools:text="100%" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Recent transactions header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/wallet_recent_title"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorTextSecondary"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvNoTxHome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/wallet_no_transactions"
                    android:textSize="13sp"
                    android:textColor="?attr/colorTextSecondary"
                    android:gravity="center"
                    android:paddingVertical="24dp"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRecentTxs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ── SECTION 2: Receive ─────────────────────────────────────────── -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/receiveSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/wallet_receive_hint"
                    android:textSize="13sp"
                    android:textColor="?attr/colorTextSecondary"
                    android:gravity="center"
                    android:layout_marginBottom="16dp" />

                <ImageView
                    android:id="@+id/ivQrCode"
                    android:layout_width="240dp"
                    android:layout_height="240dp"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="20dp"
                    android:importantForAccessibility="no"
                    android:padding="8dp"
                    android:background="#FFFFFF" />

                <TextView
                    android:id="@+id/tvAddressLoading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/wallet_loading_address"
                    android:textSize="13sp"
                    android:textColor="?attr/colorTextSecondary"
                    android:visibility="visible" />

                <TextView
                    android:id="@+id/tvPrimaryAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textColor="?attr/colorTextPrimary"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"
                    tools:text="4AbcDef…xyz" />

                <LinearLayout
                    android:id="@+id/addressActions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:visibility="gone">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopyPrimary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="@string/wallet_copy_address"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnShareAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/wallet_share_address"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ── SECTION 3: History ─────────────────────────────────────────── -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/historySection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvNoTxHistory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/wallet_no_transactions"
                android:textSize="14sp"
                android:textColor="?attr/colorTextSecondary"
                android:gravity="center"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAllTxs"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:clipToPadding="false"
                android:paddingVertical="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ── SECTION 4: Settings ────────────────────────────────────────── -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/settingsSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Server URL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/wallet_settings_server_title"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorTextSecondary"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilServerUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:hint="@string/wallet_settings_server_hint"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etServerUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:maxLines="1"
                        android:imeOptions="actionDone" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveServer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:text="@string/wallet_settings_save_server"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <!-- Manual sync -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorDivider"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/wallet_settings_sync_title"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorTextSecondary"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSyncNow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/wallet_settings_sync_now"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <TextView
                    android:id="@+id/tvLastSync"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="?attr/colorTextSecondary"
                    android:layout_marginBottom="24dp"
                    tools:text="Dernière sync : il y a 5 min" />

                <!-- Danger zone -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorDivider"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/wallet_settings_danger_title"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOrangeWarning"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/wallet_settings_wipe_warning"
                    android:textSize="12sp"
                    android:textColor="?attr/colorTextSecondary"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWipeWallet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/wallet_settings_wipe_btn"
                    app:backgroundTint="@android:color/transparent"
                    app:strokeColor="?attr/colorOrangeWarning"
                    app:strokeWidth="1.5dp"
                    android:textColor="?attr/colorOrangeWarning"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </FrameLayout>

    <!-- Bottom navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/walletBottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorToolbarBackground"
        app:menu="@menu/menu_wallet_bottom"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
